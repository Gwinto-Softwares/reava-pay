{
    "name": "gwinto/reava-pay",
    "description": "Reava Pay integration for Gwinto - Multi-tenant rental management, wallet sync, merchant onboarding & payment collection",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Reava Pay",
            "email": "dev@reavapay.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Gwinto\\ReavaPay\\": "src/",
            "ReavaPay\\Gwinto\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gwinto\\ReavaPay\\ReavaPayServiceProvider"
            ],
            "aliases": {
                "Gwinto": "ReavaPay\\Gwinto\\Facades\\Gwinto"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
